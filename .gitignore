# Old backup builds — not part of the live site
index_*.html
~$*

# Word document — not needed on the web
*.docx

# Local Claude Code session data — not source-controlled.
# Ignore everything in .claude/ EXCEPT shared team tooling.
# Note: git does not un-ignore files in an ignored dir via '!', so we
# list the ignored subdirs explicitly rather than ignoring the parent.
.claude/cache/
.claude/ide/
.claude/projects/
.claude/todos/
.claude/statsig/
.claude/settings.local.json

# macOS noise
.DS_Store

# Generated backups, climate API cache, and script output — not source-controlled
data.js.bak
scripts/weather_cache.json
scripts/simplify_preview.txt
scripts/simplify_run.txt
